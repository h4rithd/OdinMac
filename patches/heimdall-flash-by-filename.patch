+// OdinMac: ASCII case-insensitive comparison (no ctype/locale dependency).
+static bool odinmacEqualsIgnoreCase(const char *a, const char *b)
+{
+	if (!a || !b)
+		return (false);
+
+	while (*a && *b)
+	{
+		char ca = (*a >= 'A' && *a <= 'Z') ? (*a - 'A' + 'a') : *a;
+		char cb = (*b >= 'A' && *b <= 'Z') ? (*b - 'A' + 'a') : *b;
+
+		if (ca != cb)
+			return (false);
+
+		a++;
+		b++;
+	}
+
+	return (*a == '\0' && *b == '\0');
+}
